---
interface Props {
  title: string
  description: string
  canonical?: string
}

const { title, description, canonical } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Is It Agent Ready?" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <style>
      :root {
        color-scheme: dark;
        --bg: #0b1020;
        --panel: #131a2e;
        --soft: #1b2340;
        --text: #edf2ff;
        --muted: #9aa7cf;
        --accent: #7c98ff;
        --good: #3ddc97;
        --bad: #ff6b6b;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, sans-serif;
        background: radial-gradient(circle at top, #18213c, var(--bg) 55%);
        color: var(--text);
      }
      a { color: inherit; }
      a.link { color: #b9c7ff; text-decoration: none; }
      a.link:hover { text-decoration: underline; }
      main { max-width: 1120px; margin: 0 auto; padding: 32px 20px 96px; }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 999px;
        padding: 8px 14px;
        background: rgba(124, 152, 255, 0.12);
        color: #d8e0ff;
        font-size: 14px;
      }
      .card {
        background: rgba(19, 26, 46, 0.95);
        border: 1px solid rgba(154, 167, 207, 0.16);
        border-radius: 24px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      }
      .muted { color: var(--muted); }
      .grid { display: grid; gap: 24px; }
      .section-title {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        margin: 0 0 12px;
      }
      .button {
        border: 0;
        border-radius: 14px;
        padding: 14px 18px;
        font-weight: 700;
        background: linear-gradient(135deg, #7c98ff, #96adff);
        color: #09101f;
        cursor: pointer;
      }
      ul.clean {
        margin: 0;
        padding-left: 18px;
        color: var(--muted);
        line-height: 1.7;
      }
      input {
        width: 100%;
        border-radius: 14px;
        border: 1px solid rgba(154, 167, 207, 0.2);
        background: rgba(255, 255, 255, 0.03);
        color: var(--text);
        padding: 14px 16px;
        font-size: 16px;
      }
      code, pre {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      pre {
        overflow-x: auto;
        background: #0b1122;
        border-radius: 16px;
        padding: 16px;
        border: 1px solid rgba(154, 167, 207, 0.12);
      }
      @media (min-width: 900px) {
        .split {
          display: grid;
          grid-template-columns: 1.2fr 0.8fr;
          gap: 24px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
